# API authentication token — change this to a strong random string
API_TOKEN=your-secret-token-here

# Ollama server URL (host's ollama instance)
# Linux Docker default: http://172.17.0.1:11434
# Docker Desktop (Mac/Win): http://host.docker.internal:11434
OLLAMA_HOST=http://172.17.0.1:11434

# Default ollama model (used when model is not specified in the request)
OLLAMA_DEFAULT_MODEL=llama3.2

# ── agy / Antigravity CLI auth (pick one) ──────────────────────────────────────
# Option A: keyring/Google Sign-In via ~/.gemini volume mount (default, no env var needed)
# Option B: API Key — uncomment and set this to skip the volume mount
# Note: agy does not read GEMINI_API_KEY; the correct variable name is ANTIGRAVITY_API_KEY.
# ANTIGRAVITY_API_KEY=your-antigravity-api-key-here

# CLI timeout in seconds (per request)
CLI_TIMEOUT=120

# ── Container user (must match the host user) ──────────────────────────────────
# The container runs as a non-root user whose UID/GID must match yours: some
# mounted host files are 0600 (e.g. ~/.claude/.credentials.json), and claude's
# --dangerously-skip-permissions refuses to run as root. Run `id -u` / `id -g`
# on the host — if they're not 1000/1000, uncomment and set these, then
# `docker compose up --build` (a plain restart won't pick up new build args).
# HOST_UID=1000
# HOST_GID=1000
