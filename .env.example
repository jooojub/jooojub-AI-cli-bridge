# API authentication token — change this to a strong random string
API_TOKEN=your-secret-token-here

# Ollama server URL (host's ollama instance)
# Linux Docker default: http://172.17.0.1:11434
# Docker Desktop (Mac/Win): http://host.docker.internal:11434
OLLAMA_HOST=http://172.17.0.1:11434

# Default ollama model (used when model is not specified in the request)
OLLAMA_DEFAULT_MODEL=llama3.2

# ── Gemini auth (pick one) ────────────────────────────────────────────────────
# Option A: OAuth via ~/.gemini volume mount (default, no env var needed)
# Option B: API Key — uncomment and set this to skip the volume mount
# GEMINI_API_KEY=your-gemini-api-key-here

# CLI timeout in seconds (per request)
CLI_TIMEOUT=120
